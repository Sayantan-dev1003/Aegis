# ── PostgreSQL ─────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=aegis_db
POSTGRES_USER=aegis_admin
POSTGRES_PASSWORD=change_me_strong_password

# ── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://redis:6379
REDIS_PORT=6379

# ── Kafka ──────────────────────────────────────────────────
# App services connect via internal listener: kafka:29092
# Host machine connects via external listener: localhost:9092
KAFKA_BROKERS=kafka:29092
KAFKA_PORT=9092
KAFKA_TOPIC_RAW=transactions.raw
KAFKA_TOPIC_SCORED=transactions.scored
KAFKA_TOPIC_DLQ=transactions.dlq
KAFKA_CONSUMER_GROUP=ml-workers
KAFKA_RESULTS_GROUP=api-results-consumer

# ── Kafka UI ────────────────────────────────────────────────
KAFKA_UI_PORT=8085
KAFKA_CLUSTER_NAME=aegis-local

# ── API Server ─────────────────────────────────────────────
API_PORT=8080
BANK_API_KEY=bank-secret-key-abc123
INGESTOR_RATE_LIMIT_RPS=1000
JWT_SECRET=replace-with-a-256-bit-secret-at-least-32-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ── ML Worker ──────────────────────────────────────────────
MODEL_PATH=/app/model/fraud_model_v1.pkl
FEATURE_CONFIG_PATH=/app/model/feature_config.json
SHAP_MAX_FEATURES=8
ML_MAX_RETRIES=3

# ── Observability ──────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
OTEL_SERVICE_NAME_API=aegis-api-server
OTEL_SERVICE_NAME_ML=aegis-ml-worker
# Port the Go API service exposes /metrics on (Prometheus scrapes this)
# Must NOT conflict with the Prometheus container port (9090)
METRICS_PORT=9091

# Jaeger — web UI and OTLP gRPC receiver (host-side ports)
JAEGER_UI_PORT=16686
OTLP_GRPC_PORT=4317

# Prometheus
PROMETHEUS_PORT=9090

# Grafana
GRAFANA_PORT=3001
GRAFANA_USER=admin
GRAFANA_PASSWORD=change_me_grafana_password

# ── Runtime Config Defaults (seeded into system_config table) ───
FRAUD_THRESHOLD=0.75
AUTO_BLOCK_THRESHOLD=0.92
FRAUD_SPIKE_ALERT_RATE=0.05

# ── Dashboard ──────────────────────────────────────────────
DASHBOARD_PORT=3000
# These are browser-facing URLs — must be the host machine address
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_WS_URL=ws://localhost:8080/ws/feed
